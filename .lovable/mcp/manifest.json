{
  "version": 1,
  "sdk_version": "0.20.1",
  "path": "/mcp",
  "auth": {
    "type": "none"
  },
  "mcp": {
    "server": {
      "name": "fawri-lifestyle-mcp",
      "version": "0.1.0",
      "title": "Fawri Lifestyle Production"
    },
    "tools": [
      {
        "name": "production_summary",
        "title": "Production summary",
        "description": "High-level KPIs across all active designs: total orders, units in production, QC pending, ready stock, and average progress.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_designs",
        "title": "List designs",
        "description": "List all garment designs currently tracked in Fawri Lifestyle production, with customer, quantity, status, and progress.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "Sampling",
                "Approved",
                "Cutting",
                "Stitching",
                "QC",
                "Packing",
                "Ready"
              ],
              "description": "Optional filter by production status."
            },
            "customer": {
              "type": "string",
              "description": "Optional case-insensitive customer name filter."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_design",
        "title": "Get design",
        "description": "Get full details for a single design by its code (e.g. FL-2411).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "minLength": 1,
              "description": "Design code such as FL-2411."
            }
          },
          "required": [
            "code"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_samples",
        "title": "List samples",
        "description": "List sample development records with status, target date, selected materials, cost totals, and approval progress.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "Requested",
                "In Development",
                "Ready for Review",
                "Approved",
                "Rejected"
              ],
              "description": "Optional filter by sample status."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_workflow_stages",
        "title": "List workflow stages",
        "description": "List the 12 stages of the Fawri Lifestyle garment production workflow, from Sample Creation to Ready Stock.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      }
    ]
  }
}
